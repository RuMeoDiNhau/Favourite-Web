# ==============================================================================
# Tệp cấu hình mẫu (.env.example) cho Dự án Favourite-Web
# Hãy sao chép tệp này thành .env và điền các giá trị thực tế của bạn.
# Tệp .env thực tế đã được chặn trong .gitignore để bảo mật thông tin.
# ==============================================================================

# 1. AWS Credentials (Cần thiết cho S3 upload & đồng bộ khuôn mặt)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_STORAGE_BUCKET_NAME=YOUR_S3_BUCKET_NAME
AWS_S3_REGION_NAME=ap-southeast-2

# 2. Database URL (Đường dẫn kết nối cơ sở dữ liệu)
# - CHẠY LOCAL (Phát triển thử nghiệm): Bỏ trống biến này.
#   Hệ thống sẽ tự động tạo và sử dụng SQLite local (lưu tại database/app.db).
# - CHẠY PRODUCTION (Triển khai AWS RDS): Điền link kết nối PostgreSQL RDS của bạn.
#   Định dạng: postgresql://<user>:<password>@<rds_endpoint>:<port>/<db_name>
# DATABASE_URL=postgresql://postgres:password@your-rds-endpoint.amazonaws.com:5432/postgres

# 3. YouTube Data API v3 key (Cần cho /knowledge/{id}/videos — trả về 3 video
#    liên quan hiển thị trong modal bài viết). Tạo key tại
#    https://console.cloud.google.com/apis/credentials với YouTube Data API v3
#    đã enable. Nếu để trống, endpoint trả về danh sách rỗng (FE hiển thị
#    "Không tìm thấy video liên quan").
# YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_V3_KEY
