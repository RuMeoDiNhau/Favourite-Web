#Mỗi khi có thay đổi code ở backend local thì đồng bộ code local vừa thay đổi lên aws ec2 bằng cách:
1. Ở máy local: đẩy code mới lên github:

git add backend/
git commit -m "Cập nhật tính năng backend"
git push

2. Trên terminal SSH của EC2: kéo code về và build lại container như sau:

cd ~/Favourite-Web
git pull

# Di chuyển vào thư mục backend để build Docker image mới
cd backend
docker build -t fav-web-backend .

# Quay lại thư mục gốc và khởi động lại container mới
cd ..
docker stop backend-service || true
docker rm backend-service || true

# QUAN TRỌNG: Dùng -v để giữ lại database và dữ liệu khi rebuild container
# Lần đầu chạy cần tạo thư mục trước:
mkdir -p ~/Favourite-Web/database
mkdir -p ~/Favourite-Web/static/logs
mkdir -p ~/Favourite-Web/backend/ai_core/data/embeddings

docker run -d \
  --name backend-service \
  -p 80:8000 \
  --env-file ~/Favourite-Web/.env \
  -v ~/Favourite-Web/database:/app/database \
  -v ~/Favourite-Web/static:/app/static \
  -v ~/Favourite-Web/backend/ai_core/data:/app/backend/ai_core/data \
  fav-web-backend


#có thể dùng lệnh sau để kiểm tra backend-service đang RUNNING không
docker ps

curl http://localhost
# Phải trả về: {"message": "Backend is running"}


#Nếu thay đổi code ở Frontend thì sau đó đồng bộ code frontend local lên aws s3 bằng cách:
1. Ở máy local: 
cd frontend
npm run build
2. trên AWS s3 console:
Truy cập vào bucket fav-web-frontend-bucket.
Upload toàn bộ nội dung (file và thư mục con) nằm trong thư mục local frontend/dist/ đè lên các file cũ trên S3 bucket.
